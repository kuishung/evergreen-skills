{# ───────────────────────────────────────────────────────────────────
   Evergreen Sale Audit — Jinja2 template
   Renders one PDF per language pack from a single audit-data JSON.
   Schema: see audit-data.schema.md.
   ─────────────────────────────────────────────────────────────────── #}
{%- macro tick(ok) -%}
<span class="tickbox{% if not ok %} x{% endif %}">{% if ok %}✓{% else %}✗{% endif %}</span>
{%- endmacro -%}

{%- macro money(v) -%}
{%- if v is none -%}—{%- else -%}{{ '{:,.2f}'.format(v) }}{%- endif -%}
{%- endmacro -%}

{%- macro pct(v) -%}
{%- if v is none -%}—{%- else -%}{{ '{:.1f}%'.format(v) }}{%- endif -%}
{%- endmacro -%}

{%- macro signed(v) -%}
{%- if v is none -%}<span class="muted">—</span>
{%- else -%}{{ '{:+,.2f}'.format(v) if v > 0 else '{:,.2f}'.format(v) }}
{%- endif -%}
{%- endmacro -%}

{%- macro in_fr_cell(kind) -%}
{%- if kind == 'ok' -%}<span class="tickbox">✓</span>
{%- elif kind == 'agg' -%}∑
{%- else -%}<span class="tickbox x">✗</span>
{%- endif -%}
{%- endmacro -%}

{%- macro pos_result(row) -%}
{%- if row.passed -%}<span class="tickbox">{{ row.result }}</span>
{%- else -%}<span class="tickbox x">{{ row.result }}</span>{% if row.finding_n %} <span class="finding-ref">{{ labels.finding_ref_prefix }} {{ row.finding_n }}</span>{% endif %}
{%- endif -%}
{%- endmacro -%}

{# Inline cross-reference badge: "see FINDING <n>".
   Renders only when the row carries finding_n. If a row is styled
   variance/red but finding_n is missing, the audit-data is broken;
   the badge below is the audit author's responsibility to populate. #}
{%- macro finding_ref(n) -%}
{%- if n -%}<span class="finding-ref">{{ labels.finding_ref_prefix }} {{ n }}</span>
{%- endif -%}
{%- endmacro -%}
<!DOCTYPE html>
<html lang="{{ data.language|default('en') }}">
<head>
<meta charset="utf-8">
<title>{{ data.station.code }} {{ labels.title_suffix }} {{ data.business_date }}</title>
{# CSS is inlined by render-audit.py so the HTML is fully self-contained
   (no co-located audit.css needed). This is what lets anthropic-skills:pdf
   produce a styled PDF regardless of the scratch HTML's working directory. #}
<style>{{ audit_css|safe }}</style>
</head>
<body>

{# Single flowing document — pagination is handled by CSS @page rules.
   No forced page-break-after between sections, so we don't leave blank
   half-pages when a section ends short of A4. The .section-band class
   carries break-after: avoid-page to keep section headers with their
   first block of content (no orphaned headers). #}
<div class="page">

  <h1 class="title-band">{{ data.station.name_long }} ({{ data.station.code }}) {{ labels.title_suffix }} {{ data.business_date }}</h1>

  <div class="meta-strip">
    <span><span class="meta-label">{{ labels.meta.station }}:</span><span class="meta-value">{{ data.station.code }}</span></span>
    <span><span class="meta-label">{{ labels.meta.business_date }}:</span><span class="meta-value">{{ data.business_date }}</span></span>
    <span><span class="meta-label">{{ labels.meta.prepared_by }}:</span><span class="meta-value">{{ data.meta.prepared_by }}</span></span>
    <span><span class="meta-label">{{ labels.meta.fund_report }}:</span><span class="meta-value">{{ data.meta.fund_report_status }}</span></span>
  </div>

  {% if data.delivery and data.delivery.occurred %}
  <div class="callout">
    <strong>{{ labels.delivery_today }}</strong> — {{ data.delivery.summary }}
  </div>
  {% endif %}

  <h2 class="section-band">{{ labels.section_1.title }}</h2>

  <div class="headline-panel">
    <div>
      <div class="h-label">{{ labels.section_1.total_inflow }}</div>
      <div class="h-amount">RM {{ money(data.inflow.total) }}</div>
    </div>
    <div>
      <div class="h-label">{{ labels.section_1.equals_revenue }}</div>
      <div class="h-amount">RM {{ money(data.inflow.revenue) }}</div>
    </div>
    <div>
      <div class="h-label">{{ labels.section_1.plus_cfp_deposit }}</div>
      <div class="h-amount">RM {{ money(data.inflow.cfp_deposit) }}</div>
    </div>
  </div>
  <div class="headline-caption">{{ labels.section_1.caption }}</div>

  {# ── Revenue table — §9.1: Petrol (litres + BUDI95 / Collected) +
       Diesel (litres) + Buraqmart + iBing (TK only) + Lot Rental.
       Every figure that used to live in an explanatory paragraph now
       sits in a cell. ── #}
  <div class="card-row">

    <div class="card">
      <div class="card-header">{{ labels.section_1.revenue_card_header }} — RM {{ money(data.revenue.total) }}</div>
      <div class="card-body">
        <table class="audit revenue-segments">
          <thead>
            <tr>
              <th>{{ labels.section_1.col_segment }}</th>
              <th class="num">{{ labels.section_1.col_litres }}</th>
              <th class="num">{{ labels.section_1.col_budi95 }}</th>
              <th class="num">{{ labels.section_1.col_collected }}</th>
              <th class="num">{{ labels.section_1.col_rm }}</th>
              <th>{{ labels.section_1.col_share }}</th>
            </tr>
          </thead>
          <tbody>
            {% for seg in data.revenue.segments %}
            <tr>
              <td>{{ seg.name }}</td>
              <td class="num">{% if seg.litres %}{{ seg.litres }}{% else %}<span class="muted">—</span>{% endif %}</td>
              <td class="num">{% if seg.budi95_rm is not none %}{{ money(seg.budi95_rm) }}{% else %}<span class="muted">—</span>{% endif %}</td>
              <td class="num">{% if seg.collected_rm is not none %}{{ money(seg.collected_rm) }}{% else %}<span class="muted">—</span>{% endif %}</td>
              <td class="num">{{ money(seg.amount) }}</td>
              <td>
                <div class="share-cell">
                  <div class="share-track"><div class="share-fill" style="width: {{ seg.share_pct }}%;"></div></div>
                  <span class="share-pct">{{ pct(seg.share_pct) }}</span>
                </div>
              </td>
            </tr>
            {% endfor %}
          </tbody>
          <tfoot>
            <tr class="total">
              <td>{{ labels.total }}</td>
              <td class="num">{% if data.revenue.litres_total %}{{ data.revenue.litres_total }}{% else %}<span class="muted">—</span>{% endif %}</td>
              <td class="num">{{ money(data.revenue.budi95_total) }}</td>
              <td class="num">{{ money(data.revenue.collected_total) }}</td>
              <td class="num">{{ money(data.revenue.total) }}</td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <div class="card alert">
      <div class="card-header"><span class="icon">⚠</span> {{ labels.section_1.cfp_card_header }}</div>
      <div class="card-body">
        <div class="big-amount">RM {{ money(data.cfp_deposit.total) }}</div>
        {% if data.cfp_deposit.subtitle %}
        <div class="alert-caption">{{ data.cfp_deposit.subtitle }}</div>
        {% endif %}
        <table class="audit">
          <thead>
            <tr>
              <th>{{ labels.section_1.col_subchannel }}</th>
              <th class="num">{{ labels.section_1.col_amt }}</th>
              <th class="num">{{ labels.section_1.col_count }}</th>
            </tr>
          </thead>
          <tbody>
            {% for sc in data.cfp_deposit.subchannels %}
            <tr><td>{{ sc.name }}</td><td class="num">{{ money(sc.amount) }}</td><td class="num">{{ sc.count }}</td></tr>
            {% endfor %}
          </tbody>
          <tfoot>
            <tr class="total"><td>{{ labels.total }}</td><td class="num">{{ money(data.cfp_deposit.subchannels_total.amount) }}</td><td class="num">{{ data.cfp_deposit.subchannels_total.count }}</td></tr>
          </tfoot>
        </table>
      </div>
    </div>

  </div>

  {# §9.2 — Revenue Channel table.
     CFP Top-up block first (non-revenue, only if present), then revenue
     grouped by bank account with per-bank subtotals. The slip-level
     detail (Doc/Type/Amt/Date/Uniq/Acct/POS/InFR) lives directly under
     each bank's channel groups. The Cleared column is dropped — bank
     clearance moves to a separate skill.
     `page-start` forces §2 onto a new page (continues to as many
     pages as the table needs). #}

  <h2 class="section-band page-start">{{ labels.section_2.title }}</h2>

  {% if data.section_2.subtitle %}
  <div class="note" style="margin:0 0 2mm 0;">{{ data.section_2.subtitle }}</div>
  {% endif %}

  <table class="audit channel-table">
    <thead>
      <tr>
        <th>{{ labels.section_2.col_doc }}</th>
        <th>{{ labels.section_2.col_type }}</th>
        <th class="num">{{ labels.section_2.col_amt }}</th>
        <th class="center">{{ labels.section_2.col_date }}</th>
        <th class="center">{{ labels.section_2.col_uniq }}</th>
        <th>{{ labels.section_2.col_acct }}</th>
        <th class="center">{{ labels.section_2.col_pos }}</th>
        <th class="center">{{ labels.section_2.col_in_fr }}</th>
        <th>{{ labels.section_2.col_notes }}</th>
      </tr>
    </thead>
    <tbody>

      {# ── CFP Top-up block (non-revenue) — rendered only when present ── #}
      {% if data.section_2.cfp_topup %}
      <tr class="bank-header cfp">
        <td colspan="9">{{ labels.section_2.cfp_topup_label }} — {{ labels.total }} RM {{ money(data.section_2.cfp_topup.total) }}</td>
      </tr>
        {% for ch in data.section_2.cfp_topup.channels %}
          <tr class="channel-header">
            <td colspan="9"><em>{{ ch.name }}</em></td>
          </tr>
          {% for slip in ch.slips %}
          <tr>
            <td>{{ slip.doc }}</td>
            <td>{{ slip.type }}</td>
            <td class="num">{{ money(slip.amount) }}</td>
            <td class="center">{{ tick(slip.date_ok) }}</td>
            <td class="center">{{ tick(slip.uniq_ok) }}</td>
            <td>{{ slip.acct }}</td>
            <td class="center">{% if slip.pos_ok is none %}<span class="muted">n/a</span>{% else %}{{ tick(slip.pos_ok) }}{% endif %}</td>
            <td class="center">{{ in_fr_cell(slip.in_fr) }}</td>
            <td>{{ slip.notes|safe }}</td>
          </tr>
          {% endfor %}
        {% endfor %}
      <tr class="bank-subtotal cfp">
        <td colspan="2">{{ labels.section_2.cfp_topup_subtotal }}</td>
        <td class="num">{{ money(data.section_2.cfp_topup.total) }}</td>
        <td colspan="6"></td>
      </tr>
      {% endif %}

      {# ── Revenue per bank ── #}
      {% for bank in data.section_2.banks %}
      <tr class="bank-header">
        <td colspan="9">{{ bank.label }} — {{ labels.total }} RM {{ money(bank.subtotal) }}</td>
      </tr>
        {% for ch in bank.channels %}
          <tr class="channel-header">
            <td colspan="9"><em>{{ ch.name }}{% if ch.subtotal is not none %} <span class="muted">· {{ money(ch.subtotal) }}</span>{% endif %}</em></td>
          </tr>
          {% for slip in ch.slips %}
          <tr>
            <td>{{ slip.doc }}</td>
            <td>{{ slip.type }}</td>
            <td class="num">{{ money(slip.amount) }}</td>
            <td class="center">{{ tick(slip.date_ok) }}</td>
            <td class="center">{{ tick(slip.uniq_ok) }}</td>
            <td>{{ slip.acct }}</td>
            <td class="center">{% if slip.pos_ok is none %}<span class="muted">n/a</span>{% else %}{{ tick(slip.pos_ok) }}{% endif %}</td>
            <td class="center">{{ in_fr_cell(slip.in_fr) }}</td>
            <td>{{ slip.notes|safe }}</td>
          </tr>
          {% endfor %}
        {% endfor %}
      <tr class="bank-subtotal">
        <td colspan="2">{{ bank.label }} — {{ labels.section_2.subtotal_label }}</td>
        <td class="num">{{ money(bank.subtotal) }}</td>
        <td colspan="6"></td>
      </tr>
      {% endfor %}

      {# ── Receivables (BUDI95 etc.) — optional ── #}
      {% if data.section_2.receivables %}
      <tr class="bank-header receivables">
        <td colspan="9">{{ labels.section_2.receivables_label }} — {{ labels.total }} RM {{ money(data.section_2.receivables.total) }}</td>
      </tr>
        {% for ch in data.section_2.receivables.channels %}
          <tr class="channel-header">
            <td colspan="9"><em>{{ ch.name }} <span class="muted">· {{ ch.note }}</span></em></td>
          </tr>
          {% for slip in ch.slips %}
          <tr>
            <td>{{ slip.doc }}</td>
            <td>{{ slip.type }}</td>
            <td class="num">{{ money(slip.amount) }}</td>
            <td class="center">{% if slip.date_ok is none %}<span class="muted">—</span>{% else %}{{ tick(slip.date_ok) }}{% endif %}</td>
            <td class="center">{% if slip.uniq_ok is none %}<span class="muted">—</span>{% else %}{{ tick(slip.uniq_ok) }}{% endif %}</td>
            <td>{{ slip.acct }}</td>
            <td class="center">{% if slip.pos_ok is none %}<span class="muted">n/a</span>{% else %}{{ tick(slip.pos_ok) }}{% endif %}</td>
            <td class="center">{{ in_fr_cell(slip.in_fr) }}</td>
            <td>{{ slip.notes|safe }}</td>
          </tr>
          {% endfor %}
        {% endfor %}
      <tr class="bank-subtotal receivables">
        <td colspan="2">{{ labels.section_2.receivables_label }} — {{ labels.section_2.subtotal_label }}</td>
        <td class="num">{{ money(data.section_2.receivables.total) }}</td>
        <td colspan="6"></td>
      </tr>
      {% endif %}

    </tbody>
    {# ── Reconciliation row at the foot — Total inflow vs Sum of slips ── #}
    {% if data.section_2.reconciliation %}
    {% set rec = data.section_2.reconciliation %}
    <tfoot>
      <tr class="total{% if not rec.passed %} variance{% endif %}">
        <td colspan="2">{{ labels.section_2.reconciliation_label }}</td>
        <td class="num">{{ money(rec.total_inflow) }}</td>
        <td colspan="6">
          {{ labels.section_2.reconciliation_vs_slips }} RM {{ money(rec.sum_slips) }}
          {% if rec.passed %}
            → <span class="tickbox">{{ rec.result|default('✓ Pass') }}</span>
          {% else %}
            → <span class="tickbox x">{{ rec.result|default('✗ Variance') }}</span> {{ finding_ref(rec.finding_n) }}
          {% endif %}
        </td>
      </tr>
    </tfoot>
    {% endif %}
  </table>

  <div class="legend">
    <strong>{{ labels.section_2.col_date }}</strong> {{ labels.legend.date }}&nbsp;
    <strong>{{ labels.section_2.col_uniq }}</strong> {{ labels.legend.uniq }}&nbsp;
    <strong>{{ labels.section_2.col_acct }}</strong> {{ labels.legend.acct }}&nbsp;
    <strong>{{ labels.section_2.col_pos }}</strong> {{ labels.legend.pos }}&nbsp;
    <strong>{{ labels.section_2.col_in_fr }}</strong> {{ labels.legend.in_fr }}
  </div>

  {% if data.section_2.safeguards_rule_note %}
  <div class="note">{{ data.section_2.safeguards_rule_note|safe }}</div>
  {% endif %}

  {# §3 redesigned per §9.5: single arithmetic flow, no FR/Computed split.
     Old §2 fr_aggregation moves here as §3a (sibling sub-block).
     `page-start` puts §3 on a fresh page after §2 finishes. #}

  <h2 class="section-band page-start">{{ labels.section_3.title }}</h2>

  <div class="split-50">

    <div>
      {# §3 Cash highlight — arithmetic flow + FR comparison line #}
      <table class="audit cash-flow">
        <tbody>
          <tr>
            <td>{{ labels.section_3.opening }}</td>
            <td class="num">{{ money(data.section_3_cash.opening) }}</td>
          </tr>
          <tr>
            <td><span class="op">+</span> {{ labels.section_3.collected }}</td>
            <td class="num">{{ money(data.section_3_cash.collected) }}</td>
          </tr>
          {% if data.section_3_cash.collected_breakdown %}
          <tr class="breakdown">
            <td colspan="2"><span class="muted">= {{ data.section_3_cash.collected_breakdown }}</span></td>
          </tr>
          {% endif %}
          <tr>
            <td><span class="op">−</span> {{ labels.section_3.banked_in }}</td>
            <td class="num">{{ money(data.section_3_cash.banked_in) }}</td>
          </tr>
          <tr class="total">
            <td><span class="op">=</span> <strong>{{ labels.section_3.expected }}</strong></td>
            <td class="num"><strong>{{ money(data.section_3_cash.expected) }}</strong></td>
          </tr>
        </tbody>
      </table>

      {% if data.section_3_cash.fr_check %}
      {% set fc = data.section_3_cash.fr_check %}
      <div class="cash-fr-check{% if not fc.passed %} variance{% endif %}">
        <div>
          <span class="cash-fr-check-label">{{ labels.section_3.fr_closing }}:</span>
          <span class="cash-fr-check-amount">RM {{ money(fc.fr_closing) }}</span>
        </div>
        <div>
          <span class="cash-fr-check-label">{{ labels.section_3.variance_vs_expected }}:</span>
          <span class="cash-fr-check-amount">{{ signed(fc.variance) }}</span>
          {% if fc.passed %}
            <span class="tickbox">{{ fc.result|default('✓ Pass') }}</span>
          {% else %}
            <span class="tickbox x">{{ fc.result|default('✗ Variance') }}</span> {{ finding_ref(fc.finding_n) }}
          {% endif %}
        </div>
      </div>
      {% endif %}

      {% if data.section_3_cash.footer_note %}
      <div class="note">{{ data.section_3_cash.footer_note|safe }}</div>
      {% endif %}
    </div>

    <div>
      {# §3a FR aggregation check — was old §2 fr_aggregation #}
      {% if data.section_3_fr_aggregation and data.section_3_fr_aggregation.rows %}
      <h3 class="sub-header">{{ labels.section_3.fr_agg_title }}</h3>
      <p class="note" style="margin:0 0 1mm 0;">{{ labels.section_3.fr_agg_caption }}</p>
      <table class="audit">
        <thead>
          <tr>
            <th>{{ labels.section_3.col_fr_line }}</th>
            <th class="num">{{ labels.section_3.col_fr_amount }}</th>
            <th class="num">{{ labels.section_3.col_sum_slips }}</th>
            <th class="num">{{ labels.section_3.col_variance }}</th>
            <th>{{ labels.section_3.col_status }}</th>
          </tr>
        </thead>
        <tbody>
          {% for row in data.section_3_fr_aggregation.rows %}
          <tr{% if row.is_variance %} class="variance"{% endif %}>
            <td>{{ row.line }}</td>
            <td class="num">{{ money(row.fr_amount) }}</td>
            <td class="num">{{ money(row.sum_slips) }}</td>
            <td class="num">{{ signed(row.variance) }}</td>
            <td class="status">
              {{ row.status }}
              {% if row.is_variance %}{{ finding_ref(row.finding_n) }}{% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
        {% if data.section_3_fr_aggregation.total %}
        {% set ft = data.section_3_fr_aggregation.total %}
        <tfoot>
          <tr class="total{% if ft.is_variance %} variance{% endif %}">
            <td>{{ labels.total }}</td>
            <td class="num">{{ money(ft.fr_amount) }}</td>
            <td class="num">{{ money(ft.sum_slips) }}</td>
            <td class="num">{{ signed(ft.variance) }}</td>
            <td class="status">
              {{ ft.status }}
              {% if ft.is_variance %}{{ finding_ref(ft.finding_n) }}{% endif %}
            </td>
          </tr>
        </tfoot>
        {% endif %}
      </table>
      {% endif %}
    </div>

  </div>

  {# §4 + §4b live in a split-50. `page-start` on the wrapper puts the
     pair on a fresh page so they appear together with §5 underneath
     them — keeping all of §4 / §4b / §5 on one page per the user's
     section-by-page plan. #}
  <div class="split-50 page-start">

    <div>
      <h2 class="section-band">{{ labels.section_4.title }}</h2>
      <table class="audit">
        <thead>
          <tr>
            <th>{{ labels.section_4.col_product }}</th>
            <th class="num">{{ labels.section_4.col_open }}</th>
            <th class="num">{{ labels.section_4.col_deliv }}</th>
            <th class="num">{{ labels.section_4.col_sales }}</th>
            <th class="num">{{ labels.section_4.col_close }}</th>
            <th class="num">{{ labels.section_4.col_var }}</th>
          </tr>
        </thead>
        <tbody>
          {% for row in data.section_4_fuel.rows %}
          <tr>
            <td>{{ row.product }}</td>
            <td class="num">{{ row.open_l }}</td>
            <td class="num">{{ row.deliv_l }}</td>
            <td class="num">{{ row.sales_l }}</td>
            <td class="num">{{ row.close_l }}</td>
            <td class="num">{{ row.var }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% if data.section_4_fuel.footer_note %}
      <div class="note">{{ data.section_4_fuel.footer_note }}</div>
      {% endif %}
    </div>

    <div>
      <h2 class="section-band">{{ labels.section_4b.title }}</h2>
      <table class="audit">
        <thead>
          <tr>
            <th>{{ labels.section_4b.col_check }}</th>
            <th class="num">{{ labels.section_4b.col_pos }}</th>
            <th class="num">{{ labels.section_4b.col_fr }}</th>
            <th>{{ labels.section_4b.col_result }}</th>
          </tr>
        </thead>
        <tbody>
          {% for row in data.section_4b_pos_tally %}
          <tr{% if not row.passed %} class="variance"{% endif %}>
            <td>{{ row.check }}</td>
            <td class="num">{{ money(row.pos) }}</td>
            <td class="num">{{ money(row.fr) }}</td>
            <td>{{ pos_result(row) }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

  </div>

  <h2 class="section-band">{{ labels.section_5.title }}</h2>
  <p class="note" style="margin:1mm 0 4mm 0;">{{ data.section_5_checklist|safe }}</p>

  <h2 class="section-band page-start">{{ labels.section_6.title }}</h2>
  <ul class="findings">
    {% for f in data.section_6_findings %}
    <li>
      <span class="finding-title">{{ labels.section_6.finding_prefix }} {{ f.n }} — {{ f.title }}</span>
      {{ f.body }}
      <span class="action-label">{{ labels.section_6.action_label }}</span> {{ f.action }}
    </li>
    {% endfor %}
  </ul>

</div>

{# ─── Running footer ── repeated by @page rule on every printed page;
       also rendered inline as a per-.page absolutely-positioned stamp
       so the browser preview shows it too. ─── #}
<div class="page-footer">sale-audit v{{ data.skill_version }} · {{ labels.footer.generated }} {{ data.generated_at }}</div>

</body>
</html>
